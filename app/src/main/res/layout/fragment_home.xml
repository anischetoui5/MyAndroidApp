<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB">

    <!-- Main ScrollView layout (original content) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="90dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome TextView -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="#111827"
                android:layout_marginBottom="18dp" />

            <!-- Budget Overview Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/budgetLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_elevation"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E7EAF0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Budget Overview"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#111827"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvBudgetOverview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="15sp"
                        android:textColor="#374151"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/tvRemainingBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remaining: $0.00"
                        android:textSize="15sp"
                        android:textColor="@color/green"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="10dp" />

                    <ProgressBar
                        android:id="@+id/budgetProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="14dp"
                        android:progress="0"
                        android:indeterminate="false"
                        android:progressTint="@color/green"
                        android:backgroundTint="#E5E7EB" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp"
                        android:padding="12dp"
                        android:background="@drawable/bg_info_container">

                        <TextView
                            android:id="@+id/tvTotalBudget"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Budget: $0.00"
                            android:textSize="13sp"
                            android:textColor="#111827"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/divider_vertical" />

                        <TextView
                            android:id="@+id/tvTotalSpent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Spent: $0.00"
                            android:textSize="13sp"
                            android:textColor="#111827"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/divider_vertical" />

                        <TextView
                            android:id="@+id/tvDailyBudget"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Daily: $0.00"
                            android:textSize="13sp"
                            android:textColor="#111827"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- No Budget Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/noBudgetLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                android:background="@drawable/bg_card_elevation"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E7EAF0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Budget Set"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#111827"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set your monthly budget to start tracking"
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text"
                        android:gravity="center"
                        android:layout_marginBottom="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="Set Budget"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:background="@drawable/button_primary_selector"
                        app:cornerRadius="14dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_elevation"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E7EAF0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Actions"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#111827"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddExpense"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="Add Expense"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:background="@drawable/button_primary_selector"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_add_24"
                            app:iconGravity="textStart"
                            app:iconPadding="10dp"
                            android:layout_marginEnd="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Categories Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_elevation"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E7EAF0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="277dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Categories"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewCategories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Expenses Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_elevation"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E7EAF0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent Expenses"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#111827"
                        android:layout_marginBottom="10dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewExpenses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loading Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="24dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <!-- Chat Popup -->
    <LinearLayout
        android:id="@+id/chatPopup"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_card_elevation"
        android:elevation="12dp"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assistant"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#111827"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:id="@+id/scrollChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/inputMessage"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Type a message"
                android:background="@drawable/edittext_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:fontFamily="sans-serif" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:text="Send"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/button_primary_selector"
                app:cornerRadius="14dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
